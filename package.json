{
  "name": "playwright-browser-manager",
  "version": "1.0.0",
  "type": "module",
  "description": "Playwright browser manager with fingerprint & profile isolation support",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "project.xml"
  ],
  "os": [
    "win32"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "test": "mocha",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "playwright-core": ">=1.60.0"
  },
  "peerDependenciesMeta": {
    "playwright-core": {
      "optional": true
    }
  },
  "dependencies": {
    "async-lock": "1.4.1",
    "axios": "1.15.2",
    "chokidar": "^5.0.0",
    "chrome-remote-interface": "0.34.0",
    "compare-versions": "6.1.1",
    "debug": "4.4.3",
    "dedent": "1.7.2",
    "extract-zip": "2.0.1",
    "fast-glob": "3.3.3",
    "once": "1.4.0",
    "proper-lockfile": "4.1.2"
  },
  "devDependencies": {
    "@cheshire-caat/prettier-config": "^1.0.0",
    "@eslint/js": "^10.0.1",
    "jiti": "^2.7.0",
    "mocha": "^11.3.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "@types/debug": "^4.1.12",
    "@types/node": "^25.7.0",
    "@types/once": "^1.4.4",
    "@types/proper-lockfile": "^4.1.4",
    "dotenv": "^17.4.1",
    "@types/async-lock": "^1.4.2",
    "@types/chrome-remote-interface": "^0.33.0",
    "napi-macros": "^2.2.2"
  },
  "prettier": "@cheshire-caat/prettier-config"
}
